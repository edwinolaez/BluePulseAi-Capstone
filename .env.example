# ─────────────────────────────────────────────────────────────────────────────
# Project Jasper — Environment Variable Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to Git.
# Contact Edwin or Rahil via private DM for real values.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase (Owner: Rahil) ──────────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Convex (Owner: Rahil) ───────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=your_convex_deployment_url_here

# ─── Kong Gateway (Owner: Feven) ─────────────────────────────────────────────
NEXT_PUBLIC_API_KEY=your_kong_api_key_here
KONG_ADMIN_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000

# ─── FastAPI Backend (Owner: Feven) ──────────────────────────────────────────
RAILWAY_API_URL=your_railway_backend_url_here
API_SECRET_KEY=your_fastapi_secret_key_here

# ─── ML Model Service (Owner: Richard) ───────────────────────────────────────
ML_API_URL=your_ml_railway_url_here
NEXT_PUBLIC_ML_API_BASE_URL=your_ml_railway_url_here

# ─── Frontend (Owner: Reyta) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=your_railway_backend_url_here
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
